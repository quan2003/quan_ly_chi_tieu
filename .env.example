# Cấu hình IMAP. Ví dụ dưới đây là của Gmail
# Email IMAP Settings
IMAP_HOST=imap.gmail.com
IMAP_PORT=993
EMAIL_USER=your_email@gmail.com
EMAIL_PASSWORD=your_app_password

# Supabase (lấy từ Project Settings > API)
VITE_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key_here

# Chỉ dùng cho emailWatcher.js (không expose ra frontend)
SUPABASE_SERVICE_KEY=your_service_role_key_hereil@gmail.com

# Mật khẩu ứng dụng (App Password)
# Quan trọng: Không dùng mật khẩu đăng nhập, hãy tạo App Password ở mục Bảo mật của tài khoản Google.
EMAIL_PASSWORD=your_app_password
